@model AIFormationPlatform.Web.Features.Formations.ViewModels.FormationDetailViewModel
@{
    ViewData["Title"] = Model.Title;
}

<h2>@Model.Title</h2>
<hr />

<p>@Model.Description</p>

<div class="mb-3">
    <span class="badge @(Model.IsPublished ? "bg-success" : "bg-secondary")">
        @(Model.IsPublished ? "Publiée" : "Brouillon")
    </span>
    <span class="ms-2 text-muted">Créée le @Model.CreatedAt.ToString("dd/MM/yyyy")</span>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Modules (@Model.Modules.Count)</h4>
    <a asp-controller="Modules" asp-action="Create" asp-route-formationId="@Model.Id" class="btn btn-sm btn-primary">Ajouter un module</a>
</div>

@if (Model.Modules.Any())
{
    <div class="list-group">
        @foreach (var module in Model.Modules.OrderBy(m => m.SortOrder))
        {
            <div class="list-group-item">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-1">@(module.SortOrder). @module.Title</h5>
                        <small class="text-muted">@module.LessonCount leçon(s)</small>
                    </div>
                    <div>
                        <a asp-controller="Modules" asp-action="Edit" asp-route-id="@module.Id" class="btn btn-sm btn-outline-secondary">Modifier</a>
                        <a asp-controller="Lessons" asp-action="Index" asp-route-moduleId="@module.Id" class="btn btn-sm btn-outline-primary">Leçons</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info">Aucun module pour cette formation.</div>
}

<div class="mt-3">
    <a asp-controller="Quizzes" asp-action="Index" asp-route-formationId="@Model.Id" class="btn btn-outline-primary">Quiz</a>
    <a asp-action="Index" class="btn btn-secondary">Retour</a>
</div>
