@model IEnumerable<AIFormationPlatform.Web.Features.Formations.ViewModels.FormationListViewModel>
@{
    ViewData["Title"] = "Formations";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Formations</h2>
    <a asp-action="Create" class="btn btn-primary">Nouvelle formation</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Titre</th>
            <th>Modules</th>
            <th>Inscriptions</th>
            <th>Statut</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.ModuleCount</td>
                <td>@item.EnrollmentCount</td>
                <td>
                    <span class="badge @(item.IsPublished ? "bg-success" : "bg-secondary")">
                        @(item.IsPublished ? "Publiée" : "Brouillon")
                    </span>
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Détails</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Modifier</a>
                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Supprimer cette formation ?')">Supprimer</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
