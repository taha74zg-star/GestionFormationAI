@model AIFormationPlatform.Web.Features.Lessons.ViewModels.LessonFormViewModel
@{
    ViewData["Title"] = Model.Id == 0 ? "Nouvelle leçon" : "Modifier la leçon";
}

<h2>@ViewData["Title"] — @ViewBag.ModuleTitle</h2>
<hr />

<div class="row">
    <div class="col-md-10">
        <form asp-action="@(Model.Id == 0 ? "Create" : "Edit")" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ModuleId" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label">Titre</label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Content" class="form-label">Contenu pédagogique</label>
                <textarea asp-for="Content" class="form-control" rows="15"></textarea>
                <span asp-validation-for="Content" class="text-danger"></span>
                <small class="form-text text-muted">Le contenu sera utilisé par le Formateur IA pour répondre aux questions.</small>
            </div>

            <div class="mb-3">
                <label asp-for="SortOrder" class="form-label">Ordre</label>
                <input asp-for="SortOrder" class="form-control" type="number" />
                <span asp-validation-for="SortOrder" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Enregistrer</button>
            <a asp-action="Index" asp-route-moduleId="@Model.ModuleId" class="btn btn-secondary">Annuler</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
