@model IEnumerable<AIFormationPlatform.Web.Models.Lesson>
@{
    ViewData["Title"] = "Leçons";
}

<h2>Leçons — @ViewBag.ModuleTitle</h2>
<hr />

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <a asp-controller="Modules" asp-action="Index" asp-route-formationId="@ViewBag.FormationId" class="btn btn-outline-secondary btn-sm">Retour aux modules</a>
    </div>
    <a asp-action="Create" asp-route-moduleId="@ViewBag.ModuleId" class="btn btn-primary">Ajouter une leçon</a>
</div>

@if (Model.Any())
{
    <div class="list-group">
        @foreach (var lesson in Model)
        {
            <div class="list-group-item">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-1">@(lesson.SortOrder). @lesson.Title</h5>
                        <small class="text-muted">@lesson.Content.Length caractères</small>
                    </div>
                    <div>
                        <a asp-action="Details" asp-route-id="@lesson.Id" class="btn btn-sm btn-outline-info">Voir</a>
                        <a asp-action="Edit" asp-route-id="@lesson.Id" class="btn btn-sm btn-outline-secondary">Modifier</a>
                        <form asp-action="Delete" asp-route-id="@lesson.Id" asp-route-moduleId="@ViewBag.ModuleId" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Supprimer cette leçon ?')">Supprimer</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info">Aucune leçon. Ajoutez la première leçon.</div>
}
