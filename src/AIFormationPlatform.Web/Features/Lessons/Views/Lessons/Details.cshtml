@model AIFormationPlatform.Web.Features.Lessons.ViewModels.LessonDetailViewModel
@{
    ViewData["Title"] = Model.Title;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Formations" asp-action="Details" asp-route-id="@Model.FormationId">@Model.FormationTitle</a></li>
        <li class="breadcrumb-item"><a asp-controller="Lessons" asp-action="Index" asp-route-moduleId="@Model.ModuleId">@Model.ModuleTitle</a></li>
        <li class="breadcrumb-item active">@Model.Title</li>
    </ol>
</nav>

<h2>@Model.Title</h2>
<hr />

<div class="card">
    <div class="card-body">
        <div class="lesson-content" style="white-space: pre-wrap;">@Model.Content</div>
    </div>
</div>

@if (User.IsInRole("Student"))
{
    <div class="mt-4">
        <h4>Formateur IA</h4>
        <div class="card" id="ai-trainer-section">
            <div class="card-body">
                <div id="chat-messages" class="mb-3" style="max-height: 400px; overflow-y: auto;">
                </div>
                <form id="chat-form" class="d-flex gap-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="lessonId" value="@Model.Id" />
                    <input type="hidden" id="conversationId" value="" />
                    <input type="text" id="question-input" class="form-control" placeholder="Posez une question sur cette leçon..." />
                    <button type="submit" class="btn btn-primary">Envoyer</button>
                </form>
            </div>
        </div>
    </div>

    <div class="mt-3">
        @if (!Model.IsCompleted)
        {
            <form asp-controller="Progress" asp-action="MarkLessonComplete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="lessonId" value="@Model.Id" />
                <button type="submit" class="btn btn-success">Marquer comme terminée</button>
            </form>
        }
        else
        {
            <div class="alert alert-success">Cette leçon est terminée.</div>
        }
    </div>
}

@section Scripts {
    <script>
        document.getElementById('chat-form').addEventListener('submit', async function (e) {
            e.preventDefault();

            const input = document.getElementById('question-input');
            const question = input.value.trim();
            if (!question) return;

            const lessonId = document.getElementById('lessonId').value;
            const conversationId = document.getElementById('conversationId').value;
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            const messagesDiv = document.getElementById('chat-messages');
            messagesDiv.innerHTML += `<div class="mb-2"><strong>Vous :</strong> ${question}</div>`;
            input.value = '';

            messagesDiv.innerHTML += `<div class="mb-2 text-muted" id="loading-msg">Le Formateur IA réfléchit...</div>`;
            messagesDiv.scrollTop = messagesDiv.scrollHeight;

            try {
                const response = await fetch('/AITrainer/Ask', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify({
                        question: question,
                        lessonId: parseInt(lessonId),
                        conversationId: conversationId ? parseInt(conversationId) : null
                    })
                });

                const data = await response.json();
                document.getElementById('loading-msg')?.remove();

                if (data.success) {
                    messagesDiv.innerHTML += `<div class="mb-2"><strong>Formateur IA :</strong> ${data.response}</div>`;
                    if (data.conversationId) {
                        document.getElementById('conversationId').value = data.conversationId;
                    }
                } else {
                    messagesDiv.innerHTML += `<div class="mb-2 text-danger"><strong>Erreur :</strong> ${data.message}</div>`;
                }
            } catch (err) {
                document.getElementById('loading-msg')?.remove();
                messagesDiv.innerHTML += `<div class="mb-2 text-danger">Erreur de connexion.</div>`;
            }

            messagesDiv.scrollTop = messagesDiv.scrollHeight;
        });
    </script>
}
