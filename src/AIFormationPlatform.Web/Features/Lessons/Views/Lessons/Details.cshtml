@model AIFormationPlatform.Web.Features.Lessons.ViewModels.LessonDetailViewModel
@{
    ViewData["Title"] = Model.Title;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Formations" asp-action="Details" asp-route-id="@Model.FormationId">@Model.FormationTitle</a></li>
        <li class="breadcrumb-item"><a asp-controller="Lessons" asp-action="Index" asp-route-moduleId="@Model.ModuleId">@Model.ModuleTitle</a></li>
        <li class="breadcrumb-item active">@Model.Title</li>
    </ol>
</nav>

<h2>@Model.Title</h2>
<hr />

<div class="card">
    <div class="card-body">
        <div class="lesson-content" style="white-space: pre-wrap;">@Model.Content</div>
    </div>
</div>

@if (User.IsInRole("Student"))
{
    <div class="mt-4">
        <h4>Formateur IA Interactif</h4>
        <input type="hidden" id="ai-trainer-data" data-lesson-id="@Model.Id" />

        <div class="at-container">
            <div>
                <div class="at-avatar-panel">
                    <video id="at-avatar-video" autoplay playsinline></video>
                    <div class="at-avatar-placeholder" id="at-placeholder">
                        <div>🎓</div>
                        <div style="font-size: 1rem; margin-top: 8px;">Formateur IA</div>
                    </div>
                    <div class="at-status-bar">
                        <span class="at-status-dot" id="at-status-dot"></span>
                        <span id="at-status-label">Prêt à démarrer</span>
                    </div>
                </div>
                <div class="at-controls">
                    <button type="button" class="at-btn at-btn-start" id="at-btn-start" title="Démarrer l'avatar">
                        ▶
                    </button>
                    <button type="button" class="at-btn at-btn-stop" id="at-btn-stop" title="Arrêter l'avatar" disabled>
                        ■
                    </button>
                </div>
            </div>

            <div class="at-chat-panel">
                <div class="at-chat-messages" id="at-messages">
                    <div class="at-msg at-msg-ai">
                        <div class="at-msg-label">Formateur IA</div>
                        <div class="at-msg-bubble">Bonjour ! Je suis votre formateur IA. Posez-moi vos questions sur cette leçon.</div>
                    </div>
                </div>

                <div id="at-fallback" class="at-fallback">
                    <p>Utilisez le champ ci-dessous pour poser vos questions par texte.</p>
                </div>

                <form id="at-text-form" class="at-chat-input" autocomplete="off">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="lessonId" value="@Model.Id" />
                    <input type="text" id="at-text-input" class="form-control" placeholder="Posez une question sur cette leçon..." />
                    <button type="submit" id="at-send-btn">Envoyer</button>
                </form>
            </div>
        </div>
    </div>

    <div class="mt-3">
        @if (!Model.IsCompleted)
        {
            <form asp-controller="Progress" asp-action="MarkLessonComplete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="lessonId" value="@Model.Id" />
                <button type="submit" class="btn btn-success">Marquer comme terminée</button>
            </form>
        }
        else
        {
            <div class="alert alert-success">Cette leçon est terminée.</div>
        }
    </div>
}

@section Scripts {
    <link rel="stylesheet" href="~/css/ai-trainer.css" />
    <script src="~/js/ai-trainer.js"></script>
}
