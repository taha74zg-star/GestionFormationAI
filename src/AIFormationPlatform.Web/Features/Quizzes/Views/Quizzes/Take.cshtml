@model AIFormationPlatform.Web.Features.Quizzes.ViewModels.QuizTakeViewModel
@{
    ViewData["Title"] = Model.Title;
}

<h2>@Model.Title</h2>
<p class="text-muted">Durée : @Model.TimeLimitMinutes minutes — @Model.Questions.Count question(s)</p>
<hr />

<form asp-action="Submit" method="post">
    <input type="hidden" name="quizId" value="@Model.Id" />

    @for (int q = 0; q < Model.Questions.Count; q++)
    {
        var question = Model.Questions[q];
        <div class="card mb-3">
            <div class="card-header">
                <strong>Question @(q + 1)</strong> — @question.Points point(s)
            </div>
            <div class="card-body">
                <p>@question.Text</p>
                @foreach (var choice in question.AnswerChoices)
                {
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" name="answers[@question.Id]" value="@choice.Id" id="q@(question.Id)_c@(choice.Id)" required />
                        <label class="form-check-label" for="q@(question.Id)_c@(choice.Id)">@choice.Text</label>
                    </div>
                }
            </div>
        </div>
    }

    <button type="submit" class="btn btn-primary btn-lg" onclick="return confirm('Soumettre vos réponses ?')">Soumettre</button>
</form>
