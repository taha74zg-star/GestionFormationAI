@model IEnumerable<AIFormationPlatform.Web.Models.Quiz>
@{
    ViewData["Title"] = "Quiz";
}

<h2>Quiz — @ViewBag.FormationTitle</h2>
<hr />

<div class="d-flex justify-content-between align-items-center mb-3">
    <a asp-controller="Formations" asp-action="Details" asp-route-id="@ViewBag.FormationId" class="btn btn-outline-secondary btn-sm">Retour à la formation</a>
    <a asp-action="Create" asp-route-formationId="@ViewBag.FormationId" class="btn btn-primary">Créer un quiz</a>
</div>

@if (Model.Any())
{
    <div class="list-group">
        @foreach (var quiz in Model)
        {
            <div class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="mb-1">@quiz.Title</h5>
                    <small class="text-muted">@quiz.Questions.Count question(s) — @quiz.TimeLimitMinutes min</small>
                </div>
                <div>
                    <form asp-action="Delete" asp-route-id="@quiz.Id" asp-route-formationId="@ViewBag.FormationId" method="post" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Supprimer ce quiz ?')">Supprimer</button>
                    </form>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info">Aucun quiz pour cette formation.</div>
}
