@model AIFormationPlatform.Web.Features.Quizzes.ViewModels.QuizResultViewModel
@{
    ViewData["Title"] = "Résultat du quiz";
}

<h2>Résultat — @Model.QuizTitle</h2>
<hr />

<div class="card mb-4">
    <div class="card-body text-center">
        <h1 class="@(Model.Percentage >= 50 ? "text-success" : "text-danger")">@Model.Percentage%</h1>
        <h4>@Model.Score / @Model.TotalPoints points</h4>
        <p class="text-muted">Le @Model.AttemptedAt.ToString("dd/MM/yyyy à HH:mm")</p>
    </div>
</div>

<h4>Détail des réponses</h4>
@foreach (var question in Model.Questions)
{
    <div class="card mb-2 @(question.IsCorrect ? "border-success" : "border-danger")">
        <div class="card-body">
            <p><strong>@question.Text</strong></p>
            <p>Votre réponse : <span class="@(question.IsCorrect ? "text-success" : "text-danger")">@question.SelectedAnswer</span></p>
            @if (!question.IsCorrect)
            {
                <p>Bonne réponse : <span class="text-success">@question.CorrectAnswer</span></p>
            }
        </div>
    </div>
}

<div class="mt-3">
    <a asp-controller="Enrollments" asp-action="MyFormations" class="btn btn-primary">Mes formations</a>
</div>
