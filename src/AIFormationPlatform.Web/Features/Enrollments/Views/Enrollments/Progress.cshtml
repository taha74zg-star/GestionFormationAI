@model AIFormationPlatform.Web.Features.Enrollments.ViewModels.ProgressViewModel
@{
    ViewData["Title"] = Model.FormationTitle;
}

<h2>@Model.FormationTitle</h2>
<hr />

<div class="mb-4">
    <div class="progress" style="height: 30px;">
        <div class="progress-bar bg-success" role="progressbar" style="width: @(Model.ProgressPercentage)%">
            @Model.ProgressPercentage% — @Model.CompletedLessons / @Model.TotalLessons
        </div>
    </div>
</div>

@if (Model.ProgressPercentage >= 100 && Model.TotalLessons > 0)
{
    <div class="alert alert-success d-flex justify-content-between align-items-center">
        <span>Félicitations ! Vous avez terminé cette formation.</span>
        <form asp-controller="Certificates" asp-action="Download" asp-route-formationId="@Model.FormationId" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-success btn-sm">Télécharger le certificat</button>
        </form>
    </div>
}

@foreach (var module in Model.Modules)
{
    <div class="card mb-3">
        <div class="card-header">
            <h5 class="mb-0">@module.Title</h5>
        </div>
        <div class="list-group list-group-flush">
            @foreach (var lesson in module.Lessons)
            {
                <div class="list-group-item d-flex justify-content-between align-items-center">
                    <span>
                        @if (lesson.IsCompleted)
                        {
                            <span class="text-success me-2">&#10003;</span>
                        }
                        @lesson.Title
                    </span>
                    <a asp-controller="Lessons" asp-action="Details" asp-route-id="@lesson.Id" class="btn btn-sm btn-outline-primary">
                        @(lesson.IsCompleted ? "Revoir" : "Commencer")
                    </a>
                </div>
            }
        </div>
    </div>
}
