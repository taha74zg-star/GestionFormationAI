@model IEnumerable<AIFormationPlatform.Web.Models.Module>
@{
    ViewData["Title"] = "Modules";
}

<h2>Modules — @ViewBag.FormationTitle</h2>
<hr />

<div class="d-flex justify-content-between align-items-center mb-3">
    <a asp-controller="Formations" asp-action="Details" asp-route-id="@ViewBag.FormationId" class="btn btn-outline-secondary btn-sm">Retour à la formation</a>
    <a asp-action="Create" asp-route-formationId="@ViewBag.FormationId" class="btn btn-primary">Ajouter un module</a>
</div>

@if (Model.Any())
{
    <div class="list-group">
        @foreach (var module in Model)
        {
            <div class="list-group-item">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-1">@(module.SortOrder). @module.Title</h5>
                        <p class="mb-1 text-muted">@module.Description</p>
                    </div>
                    <div>
                        <a asp-controller="Lessons" asp-action="Index" asp-route-moduleId="@module.Id" class="btn btn-sm btn-outline-primary">Leçons</a>
                        <a asp-action="Edit" asp-route-id="@module.Id" class="btn btn-sm btn-outline-secondary">Modifier</a>
                        <form asp-action="Delete" asp-route-id="@module.Id" asp-route-formationId="@ViewBag.FormationId" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Supprimer ce module ?')">Supprimer</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info">Aucun module. Ajoutez le premier module.</div>
}
