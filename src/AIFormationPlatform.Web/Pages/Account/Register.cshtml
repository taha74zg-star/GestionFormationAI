@page
@model AIFormationPlatform.Web.Pages.Account.RegisterModel
@{ ViewData["Title"] = "Inscription"; }
<div class="auth-shell">
    <section class="auth-panel auth-panel-copy d-none d-lg-flex"><div><span class="auth-kicker"><i class="bi bi-mortarboard-fill"></i> AIFormation</span><h1>Commencez à apprendre dès aujourd'hui.</h1><p>Votre compte apprenant vous donne accès à votre espace personnel et à vos formations.</p></div><div class="auth-orb auth-orb-one"></div><div class="auth-orb auth-orb-two"></div></section>
    <section class="auth-panel auth-panel-form"><div class="auth-form-wrap"><p class="eyebrow">Créer un compte</p><h1 class="h2 mb-2">Rejoignez AIFormation</h1><p class="text-secondary mb-4">Votre compte sera créé avec le rôle <strong>Apprenant</strong>.</p>
        <form method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
            <div class="row g-3"><div class="col-md-6"><label asp-for="Input.Prenom" class="form-label">Prénom</label><input asp-for="Input.Prenom" class="form-control" autocomplete="given-name" /><span asp-validation-for="Input.Prenom" class="text-danger small"></span></div><div class="col-md-6"><label asp-for="Input.Nom" class="form-label">Nom</label><input asp-for="Input.Nom" class="form-control" autocomplete="family-name" /><span asp-validation-for="Input.Nom" class="text-danger small"></span></div></div>
            <div class="mt-3"><label asp-for="Input.Email" class="form-label">Adresse e-mail</label><input asp-for="Input.Email" class="form-control" placeholder="vous@exemple.com" autocomplete="email" /><span asp-validation-for="Input.Email" class="text-danger small"></span></div>
            <div class="mt-3"><label asp-for="Input.Password" class="form-label">Mot de passe</label><input asp-for="Input.Password" class="form-control" placeholder="8 caractères ou plus" autocomplete="new-password" /><span asp-validation-for="Input.Password" class="text-danger small"></span></div>
            <div class="mt-3 mb-4"><label asp-for="Input.ConfirmPassword" class="form-label">Confirmer le mot de passe</label><input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" /><span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span></div>
            <button class="btn btn-primary w-100" type="submit">Créer mon compte <i class="bi bi-arrow-right ms-1"></i></button>
        </form><p class="text-center text-secondary mt-4 mb-0">Déjà inscrit ? <a asp-page="Login" class="fw-bold">Se connecter</a></p></div>
    </section>
</div>
