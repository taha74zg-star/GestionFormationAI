@model AIFormationPlatform.Web.Pages.Shared.FormationCardViewModel
<article class="card formation-card h-100 border-0">
    <img class="formation-card-image" src="@(Model.ImageUrl ?? "https://placehold.co/800x500/e9edff/243b8f?text=AIFormation")" alt="" />
    <div class="card-body d-flex flex-column p-4">
        <div class="d-flex justify-content-between align-items-center mb-3"><span class="badge badge-category">@Model.Categorie</span><span class="text-secondary small">@Model.Niveau</span></div>
        <h3 class="h5 mb-2">@Model.Titre</h3>
        @if (!string.IsNullOrWhiteSpace(Model.Formateur)) { <p class="text-secondary small mb-4"><i class="bi bi-person-circle me-1"></i>@Model.Formateur</p> }
        <div class="mt-auto">
            <div class="d-flex justify-content-between small mb-2"><span>Progression</span><strong>@Model.Progression%</strong></div>
            <div class="progress mb-3"><div class="progress-bar" style="width: @Model.Progression%"></div></div>
            <a class="btn btn-outline-primary w-100" href="@Model.Href">Accéder à la formation <i class="bi bi-arrow-right ms-1"></i></a>
        </div>
    </div>
</article>
