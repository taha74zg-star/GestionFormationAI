@page "/Admin/Comptes"
@model AIFormationPlatform.Web.Pages.Admin.ComptesModel
@{ ViewData["Title"] = "Comptes"; }
<h1>Comptes utilisateurs</h1><div class="card border-0 p-4 mb-4"><div class="d-flex align-items-center justify-content-between gap-3"><div><p class="eyebrow mb-1">Test rapide</p><h2 class="h4 mb-1">Formateur IA Anam</h2><p class="text-secondary mb-0">Votre session Admin sera remplacée par le compte Formateur IA.</p></div><form method="post" asp-page-handler="StartAiTrainer"><button class="btn btn-success btn-lg"><i class="bi bi-play-circle me-2"></i>Démarrer le Formateur IA</button></form></div></div><div class="row g-4"><div class="col-lg-5"><form method="post" class="card p-4 border-0"><div asp-validation-summary="ModelOnly" class="text-danger"></div><input asp-for="Input.Prenom" class="form-control mb-2" placeholder="Prénom"/><input asp-for="Input.Nom" class="form-control mb-2" placeholder="Nom"/><input asp-for="Input.Email" class="form-control mb-2" placeholder="E-mail"/><input asp-for="Input.Password" class="form-control mb-2" placeholder="Mot de passe"/><select asp-for="Input.Role" class="form-select mb-3"><option>Apprenant</option><option>Formateur</option><option>Admin</option></select><button class="btn btn-primary">Créer le compte</button></form></div><div class="col-lg-7"><div class="card border-0"><table class="table mb-0"><thead><tr><th>Nom</th><th>E-mail</th></tr></thead><tbody>@foreach(var c in Model.Comptes){<tr><td>@c.Prenom @c.Nom</td><td>@c.Email</td></tr>}</tbody></table></div></div></div>
