@page "/Admin/Formations/{formationId:int}/Modules/{id:int}/Delete"
@model AIFormationPlatform.Web.Pages.Admin.Formations.Modules.DeleteModel
<h1>Supprimer le module</h1>
<p>Confirmez-vous la suppression de <strong>@Model.Module.Titre</strong> ?</p>
<form method="post"><button type="submit">Supprimer</button> <a asp-page="Index" asp-route-formationId="@Model.Module.FormationId">Annuler</a></form>
