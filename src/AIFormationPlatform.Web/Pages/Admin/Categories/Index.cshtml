@page
@model AIFormationPlatform.Web.Pages.Admin.Categories.IndexModel
@{
    ViewData["Title"] = "Catégories";
}

<h1>Catégories</h1>
<p><a asp-page="Create">Créer une catégorie</a> · <a href="/Admin">Administration</a></p>

<table>
    <thead><tr><th>Nom</th><th>Parent</th><th>Ordre</th><th></th></tr></thead>
    <tbody>
    @foreach (var categorie in Model.Categories)
    {
        <tr>
            <td>@categorie.Nom</td>
            <td>@categorie.Parent?.Nom</td>
            <td>@categorie.Ordre</td>
            <td>
                <a asp-page="Details" asp-route-id="@categorie.Id">Détails</a> |
                <a asp-page="Edit" asp-route-id="@categorie.Id">Modifier</a> |
                <a asp-page="Delete" asp-route-id="@categorie.Id">Supprimer</a>
            </td>
        </tr>
    }
    </tbody>
</table>
