@page "/Apprenant"
@model AIFormationPlatform.Web.Pages.Apprenant.IndexModel
@{ ViewData["Title"]="Découvrir"; }
<div class="mb-5"><p class="eyebrow">Catalogue</p><h1>Apprenez ce qui compte pour vous.</h1><p class="text-secondary">Des formations conçues pour progresser à votre rythme.</p></div><form method="get" class="row g-2 mb-4"><div class="col-md"><input name="search" value="@Model.Search" class="form-control" placeholder="Rechercher une formation..." /></div><div class="col-md-3"><select name="category" class="form-select"><option value="">Toutes les catégories</option>@foreach(var c in Model.Categories){<option selected="@(c==Model.Category)" value="@c">@c</option>}</select></div><div class="col-md-auto"><button class="btn btn-primary">Rechercher</button></div></form><div class="row g-4">@foreach(var f in Model.Formations){<div class="col-md-6 col-lg-4"><article class="card formation-card h-100 border-0"><img class="formation-card-image" src="@(f.ImageUrl??"https://placehold.co/800x500/e9edff/263b8f?text=AIFormation")" alt=""/><div class="card-body p-4"><span class="badge badge-category">@f.Categorie</span>@if(Model.Inscrites.Contains(f.Id)){<span class="badge badge-quiz ms-1">Inscrit</span>}<h2 class="h5 mt-3">@f.Titre</h2><p class="text-secondary small">@f.Niveau · @f.DureeEnMinutes min</p><a class="btn btn-outline-primary w-100" asp-page="Formation" asp-route-id="@f.Id">Voir la formation</a></div></article></div>}</div>
